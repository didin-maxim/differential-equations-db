{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Differential Equations Task Cluster Collection",
  "type": "object",
  "required": [
    "task_clusters_version",
    "clusters"
  ],
  "properties": {
    "task_clusters_version": {
      "type": "integer",
      "minimum": 1
    },
    "clusters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task_cluster"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "task_cluster": {
      "type": "object",
      "required": [
        "id",
        "title",
        "status",
        "goal",
        "duplicate_signals",
        "canonical_solution_plan",
        "allowed_variants",
        "saturation_policy",
        "deficit_policy",
        "representative_card_ids",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "deficit",
            "active",
            "watch",
            "saturated"
          ]
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "duplicate_signals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "canonical_solution_plan": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowed_variants": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/allowed_variant"
          }
        },
        "saturation_policy": {
          "$ref": "#/$defs/saturation_policy"
        },
        "deficit_policy": {
          "$ref": "#/$defs/deficit_policy"
        },
        "representative_card_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "allowed_variant": {
      "type": "object",
      "required": [
        "id",
        "description",
        "use_when"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_]*$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "use_when": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "saturation_policy": {
      "type": "object",
      "required": [
        "status",
        "target_representative_count",
        "do_not_add_when"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "deficit",
            "watch",
            "saturated"
          ]
        },
        "target_representative_count": {
          "type": "integer",
          "minimum": 0
        },
        "do_not_add_when": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "deficit_policy": {
      "type": "object",
      "required": [
        "priority",
        "need",
        "prefer_new_cards"
      ],
      "properties": {
        "priority": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "need": {
          "type": "string",
          "minLength": 1
        },
        "prefer_new_cards": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    }
  }
}
